# {{ ansible_managed }}
# OVH API credentials for Caddy's DNS-01 ACME challenge (caddy-dns/ovh plugin).
# Loaded by systemd as an EnvironmentFile; read in the Caddyfile via {env.*}.
# Scoped token (routes /domain/zone/tipunchlabs.fr/*) — same as the DNS Terraform.
OVH_APPLICATION_KEY={{ caddy_ovh_application_key }}
OVH_APPLICATION_SECRET={{ caddy_ovh_application_secret }}
OVH_CONSUMER_KEY={{ caddy_ovh_consumer_key }}
