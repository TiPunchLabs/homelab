{{ ansible_managed | comment }}
# Based on official: https://github.com/moghtech/komodo/blob/main/compose/compose.env

# =============================================================================
# Shared
# =============================================================================
COMPOSE_KOMODO_IMAGE_TAG="{{ komodo_image_tag }}"
COMPOSE_KOMODO_BACKUPS_PATH={{ komodo_backups_dir }}
TZ={{ komodo_tz }}

# DB credentials (MongoDB)
KOMODO_DATABASE_USERNAME={{ komodo_db_username }}
KOMODO_DATABASE_PASSWORD={{ vault_komodo_db_password }}

# =============================================================================
# Komodo Core
# =============================================================================
KOMODO_HOST={{ komodo_host }}
KOMODO_TITLE=Komodo

# Core <-> Periphery key exchange (shared via `keys` named volume)
KOMODO_PERIPHERY_PUBLIC_KEY=file:/config/keys/periphery.pub

# Local username/password auth
KOMODO_LOCAL_AUTH={{ komodo_local_auth }}
KOMODO_INIT_ADMIN_USERNAME={{ komodo_admin_username }}
KOMODO_INIT_ADMIN_PASSWORD={{ vault_komodo_admin_password }}

# First Server auto-registered on boot (dockhost itself, via Periphery)
KOMODO_FIRST_SERVER_NAME={{ komodo_first_server_name }}

KOMODO_DISABLE_CONFIRM_DIALOG=false
KOMODO_DISABLE_INIT_RESOURCES=false

# Webhook + JWT secrets
KOMODO_WEBHOOK_SECRET={{ vault_komodo_webhook_secret }}
KOMODO_JWT_SECRET={{ vault_komodo_jwt_secret }}
KOMODO_JWT_TTL="{{ komodo_jwt_ttl }}"

KOMODO_MONITORING_INTERVAL="{{ komodo_monitoring_interval }}"
KOMODO_RESOURCE_POLL_INTERVAL="{{ komodo_resource_poll_interval }}"

KOMODO_DISABLE_USER_REGISTRATION={{ komodo_disable_user_registration }}
KOMODO_ENABLE_NEW_USERS={{ komodo_enable_new_users }}
KOMODO_DISABLE_NON_ADMIN_CREATE={{ komodo_disable_non_admin_create }}
KOMODO_TRANSPARENT_MODE={{ komodo_transparent_mode }}

# OIDC / OAuth disabled for POC
KOMODO_OIDC_ENABLED=false
KOMODO_GITHUB_OAUTH_ENABLED=false
KOMODO_GOOGLE_OAUTH_ENABLED=false

KOMODO_LOGGING_PRETTY=false
KOMODO_PRETTY_STARTUP_CONFIG=false

# =============================================================================
# Komodo Periphery (agent on dockhost)
# =============================================================================
PERIPHERY_CORE_ADDRESS=ws://core:9120
PERIPHERY_CONNECT_AS={{ komodo_first_server_name }}
PERIPHERY_CORE_PUBLIC_KEYS=file:/config/keys/core.pub
PERIPHERY_ROOT_DIRECTORY={{ komodo_periphery_root }}

PERIPHERY_DISABLE_TERMINALS=false
PERIPHERY_DISABLE_CONTAINER_TERMINALS=false

PERIPHERY_INCLUDE_DISK_MOUNTS=/etc/hostname

PERIPHERY_LOGGING_PRETTY=false
PERIPHERY_PRETTY_STARTUP_CONFIG=false
